# Copy this file to .env and fill in real values before running.
# Docker Compose will prefer .env over this file.

# --- PostgreSQL (matches docker-compose.yml defaults) ---
POSTGRES_DB=community_reports
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/community_reports

# --- Backend ---
# Bug fix: Use a real random secret in production. Never leave this as-is.
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d
PORT=5000

# --- CORS ---
# Comma-separated list of allowed browser origins.
# In Docker dev: http://localhost:5173
# In production: https://yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# --- Cloudinary (optional — local disk used if blank) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Frontend (Vite injects these at build time) ---
# Must be reachable from the USER'S BROWSER, not from inside Docker.
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
